#!/usr/bin/env bash
# .githooks/pre-push
#
# Activated by:
#   git config core.hooksPath .githooks
#
# Per ADR-0076 D4: pre-push runs ONLY the chunk-close ratchets, NOT
# the commit gate again. Rationale: every staged commit has already
# passed the pre-commit hook (--fast static checks); the loop's
# Step 5 (test) + Step 4 (lint) ran before commit. Re-running the
# commit gate at push time was pure duplication that added ~30 s
# to every push without catching anything pre-commit didn't.
#
# Three cheap audit gates — all run on every push, all <1s when
# they have nothing to do:
# - skip_impl_ratchet uses cached test logs (or warns if absent);
# - check_skip_taxonomy validates SKIP-* emissions vs ADR-0078 table
#   (catches new tokens landing without classification);
# - check_skip_taxonomy_pairing validates Paired-artifact resolution
#   (catches missing ADR file refs).
#
# The full 3-host merge gate (Mac + ubuntunote + windowsmini
# test-all) lives in `scripts/gate_merge.sh` and is invoked
# **manually** for `main` pushes (A13 merge gate), and by CI on the
# pull_request from a `develop/*` feature branch. Per-push to a
# feature branch does NOT run the merge gate — per-chunk
# Mac + ubuntunote (background, ADR-0076 D3) is the autonomous
# discipline.
#
# Skipping the hook with `git push --no-verify` is forbidden by
# ROADMAP §14.

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# (check_subrow_exit --gate retired: it was a §9.12-X campaign chunk-close
# ratchet that misfired on the v1→v2 merge and normal `main` pushes; the
# campaign is complete, so the gate is dormant/obsolete.)

if [ -x scripts/check_skip_impl_ratchet.sh ]; then
    echo "[pre-push] check_skip_impl_ratchet --gate ..."
    bash scripts/check_skip_impl_ratchet.sh --gate
fi

if [ -x scripts/check_skip_taxonomy.sh ]; then
    echo "[pre-push] check_skip_taxonomy --gate ..."
    bash scripts/check_skip_taxonomy.sh --gate
fi

if [ -x scripts/check_skip_taxonomy_pairing.sh ]; then
    echo "[pre-push] check_skip_taxonomy_pairing --gate ..."
    bash scripts/check_skip_taxonomy_pairing.sh --gate
fi
