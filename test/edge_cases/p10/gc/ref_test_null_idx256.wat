;; Wasm 3.0 GC: ref.test_null at CONCRETE type index 256 (D-453 JIT nullbit fix).
;; This is the TRUE trigger of the bit-packing bug. 257 types so type index 256
;; (= 0x100) needs a multi-byte SLEB128 heap-type immediate, and 256 is the
;; smallest index whose bit 8 is set. The JIT ref.test_null emit handler ORs a
;; null-handling flag into the trampoline arg; the flag used to live at bit 8
;; (0x100), which collides with index 256: the trampoline stripped bit 8 and
;; corrupted the encoded index 256 -> 0, type-testing against the WRONG type.
;; Fixed by moving the JIT null flag to bit 30 (0x4000_0000), below the
;; concrete-tag (bit 31) and above any in-range typeidx (bits 0..29).
;;
;; To make the corruption observable the type-test must DISCRIMINATE: type 256
;; has a distinct shape (field i64) from type 0 (field i32). A type-256 struct
;; ref.test_null'd against (ref null 256) is a match (-> 1); if the index were
;; corrupted to 0 the canonical-id / supertype-chain test against type 0 would
;; FAIL (-> 0). With the fix the index survives and the answer is 1.
;;
;; `test`: struct.new $256 (field = ignored) -> ref.test (ref null 256)
;; -> 1. The edge runner executes via engine.runner.runI32Export, which
;; JIT-compiles and runs native code, so this exercises the JIT ref_test emit
;; handler + jitGcRefTest trampoline on the idx>=256 path.
;;
;; Stress axes (test_discipline.md §1): GC nullable concrete-type test x
;; multi-byte SLEB heap-type immediate x JIT null-flag/index bit boundary at
;; index 256. Returns 1 (matched).
(module
  (type (;0;) (struct (field i32)))
  (type (;1;) (struct (field i32)))
  (type (;2;) (struct (field i32)))
  (type (;3;) (struct (field i32)))
  (type (;4;) (struct (field i32)))
  (type (;5;) (struct (field i32)))
  (type (;6;) (struct (field i32)))
  (type (;7;) (struct (field i32)))
